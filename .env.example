# Server
NODE_ENV=development
PORT=5000
TRUST_PROXY=1

# Frontend origin(s) for CORS — comma-separated list
# Production example: https://yourdomain.com
CLIENT_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://localhost:27017/portfolio

# JWT Secret (used for admin auth) — REQUIRED, min 32 chars
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-chars-long

# Email (used for contact form) — optional
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# AI providers (at least one required for /api/chat and /api/ats-score)
OPENAI_API_KEY=sk-your-openai-api-key-here
GROQ_API_KEY=gsk-your-groq-api-key-here

# Salt for hashing analytics IPs (any random string)
ANALYTICS_SALT=change-me-to-a-random-string

# Minimum ms between contact submissions from the same email (0 = disabled)
CONTACT_MIN_INTERVAL_MS=0
