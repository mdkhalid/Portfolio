# =============================================================================
# Portfolio — Environment Variables
# Copy this file to .env and fill in the required values.
#   cp .env.example .env
# =============================================================================

# ─── Required ────────────────────────────────────────────────────────────────

# MongoDB connection string (e.g. mongodb://localhost:27017/portfolio)
MONGODB_URI=mongodb://localhost:27017/portfolio

# JWT secret used to sign admin auth tokens (minimum 32 characters, use a
# strong random value — run `openssl rand -base64 48` to generate one)
JWT_SECRET=change_me_to_a_random_32_character_string

# ─── Server ──────────────────────────────────────────────────────────────────

# Port the server listens on (default: 5000)
PORT=5000

# Node environment (development | production | test)
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────────────

# Allowed client origin(s). Comma-separated if multiple.
# In development this is typically http://localhost:5173 (Vite default).
# When empty, the server's built-in CORS middleware allows common patterns.
CLIENT_URL=http://localhost:5173

# Number of reverse-proxy hops to trust for correct IP detection.
# Set to 0 if running directly without a proxy (default: 1).
TRUST_PROXY=1

# ─── AI Providers (at least one required for Chat & ATS features) ────────────

# OpenAI API key (for GPT-4o Mini chat / ATS scoring)
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Groq API key (free alternative for Llama 3.3 70B chat / ATS scoring)
# Get yours at https://console.groq.com/keys
GROQ_API_KEY=

# ─── Email (optional — for contact form notifications) ───────────────────────

# SMTP credentials (currently used for contact form email forwarding)
EMAIL_USER=
EMAIL_PASS=

# ─── Analytics (optional) ────────────────────────────────────────────────────

# Salt used to hash visitor IPs for unique-visitor counting.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ANALYTICS_SALT=

# Minimum interval (ms) between messages from the same email address.
# Set to 0 to disable. Default: 60000 (1 minute)
CONTACT_MIN_INTERVAL_MS=60000
