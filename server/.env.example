# MongoDB
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/portfolio

# OpenAI API (paid, used when aiProvider is set to 'openai')
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Groq API (free, used when aiProvider is set to 'groq')
# Get your key at https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# Email (optional — for contact form notifications)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Server port (default: 5000)
PORT=5000

# Analytics salt for IP hashing (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ANALYTICS_SALT=
